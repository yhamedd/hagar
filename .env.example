# Local work: copy to .env.development.local.
# Replit: add these through Secrets instead of creating or uploading an env file.
APP_ENV=development
DATABASE_ENVIRONMENT=development
DATABASE_URL=postgresql://user:password@host/hagar_development?sslmode=require

# Generate with a password manager or: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-random-characters

# Required only while running the initial seed
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-a-unique-12-character-password

# Shared read-only technician calendar portal login (used during initial seed)
TECHNICIAN_PORTAL_USERNAME=technicians
TECHNICIAN_PORTAL_PASSWORD=replace-with-a-unique-12-character-password
